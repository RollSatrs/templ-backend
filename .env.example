PORT=3001

DATABASE_URL=postgresql://postgres:password@localhost:5432/dbname

# URL фронтенда (используется в ссылках письма)
FRONT_URL=http://localhost:3000

# Секретный ключ для подписи JWT токенов
# Сгенерировать командой: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=

OPENAI_API=

# SMTP настройки для отправки email (сброс пароля)
# Для Gmail: включи 2FA и создай App Password на https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_without_spaces
SMTP_FROM="Название проекта <no-reply@example.com>"
